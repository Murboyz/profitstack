# ProfitStack environment template
#
# Copy to ".env.local" at the repo root and fill in values. .env.local is gitignored.
#
# Supabase (Settings → API in the Supabase dashboard):
# The Node server reads these exact names (see backend/src/supabase-client.mjs).
# NEXT_PUBLIC_* aliases below are optional documentation only — not loaded by this app unless you add them.

NEXT_PUBLIC_APP_NAME=ProfitStack
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
HOUSECALL_PRO_CLIENT_ID=
HOUSECALL_PRO_CLIENT_SECRET=
ENCRYPTION_KEY=
CRON_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_DISPLAY=$299/month
# Stripe webhook signing secret (whsec_...) from the webhook endpoint in Stripe dashboard.
# Required for POST /api/stripe/webhook to accept events.
STRIPE_WEBHOOK_SECRET=
BILLING_SUPPORT_EMAIL=support@example.com
APP_URL=http://127.0.0.1:8787
