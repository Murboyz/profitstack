{
  "manifest_version": 3,
  "name": "ProfitStack HCP Helper",
  "version": "0.1.0",
  "description": "Capture the active Housecall Pro browser session and save it to ProfitStack for the logged-in org.",
  "action": {
    "default_title": "ProfitStack HCP Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://pro.housecallpro.com/*"
  ]
}
